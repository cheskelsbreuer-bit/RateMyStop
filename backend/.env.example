# Copy this file to .env and fill in real values for production.

# Database — SQLite for local, Postgres for production (Railway gives you DATABASE_URL automatically)
DATABASE_URL=sqlite:///./ratemystop.db

# Where uploaded files are stored on disk
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# CORS — comma-separated list of allowed frontend origins.
# Add your Vercel URL here once deployed, e.g. https://ratemystop.vercel.app
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://localhost:8080

# Resend — leave blank to disable email sending (complaints will still be saved to DB)
# Get a key at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=
RESEND_FROM=RateMyStop <complaints@yourdomain.com>
